# Copy to questions.yaml and add your own questions.
# Do not commit questions.yaml if it contains private/sensitive content (it is in .gitignore).
#
# Format: each question has an id (e.g. q1, q2), then:
#   text: question text
#   options: list of [display_label, answer_key] (answer_key is usually A, B, C, D)
#   correct: the answer_key of the correct option

q1:
  text: "Example question text?"
  options:
    - [First option, A]
    - [Second option, B]
    - [Third option, C]
    - [Fourth option, D]
  correct: A

q2:
  text: "Another example question?"
  options:
    - [Option one, A]
    - [Option two, B]
  correct: B
